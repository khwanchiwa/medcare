# Origin ของ MedCare API ที่ Next.js ใช้ proxy คำขอ /api/backend/* ไปหา (ฝั่งเซิร์ฟเวอร์)
# ใช้เมื่อรัน next dev / next start บนเครื่องหรือเครือข่ายเดียวกับ backend
BACKEND_ORIGIN=http://127.0.0.1:8000

# ตั้งค่านี้เมื่อให้เบราว์เซอร์เรียก API ข้ามโดเมนโดยตรง (เช่น frontend บน Vercel, backend แยกโฮสต์)
# ค่าต้องรวม prefix /api/v1 และถูกฝังตอน build — ต้องตั้งก่อน next build เท่านั้น
# เว้นว่างไว้จะใช้เส้นทาง /api/backend ผ่าน rewrite ด้านบนแทน
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
