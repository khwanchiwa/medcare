APP_NAME=MedCare API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_ORIGINS=["http://localhost:3000"]
FRONTEND_ORIGIN_REGEX=^https://medcare(?:-[a-z0-9-]+)?\.vercel\.app$

# Supabase Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Backend only. Never expose this value through NEXT_PUBLIC_* or commit it.
SUPABASE_SECRET_KEY=sb_secret_your-key
# Development only. Keep false in production so users must verify their email.
SUPABASE_AUTO_CONFIRM_EMAIL=false

# Local PJ_OCR69 FastAPI service (run it on a different port from MedCare API)
OCR_API_URL=http://127.0.0.1:8001
OCR_TIMEOUT_SECONDS=120

# Google Cloud OAuth 2.0 Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback
FRONTEND_URL=http://localhost:3000
