APP_NAME=MedCare API
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
FRONTEND_ORIGINS=["https://app.example.com"]
FRONTEND_ORIGIN_REGEX=^https://medcare(?:-[a-z0-9-]+)?\.vercel\.app$

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SECRET_KEY=sb_secret_your-key
SUPABASE_AUTO_CONFIRM_EMAIL=false

# Use the private service URL when OCR runs in the same deployment network.
OCR_API_URL=http://ocr:8001
OCR_TIMEOUT_SECONDS=120

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.example.com/api/v1/integrations/google/callback
FRONTEND_URL=https://app.example.com
